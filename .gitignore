# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# JS/TS deps and build outputs (all levels)
**/node_modules/
**/dist/
**/build/
**/.next/
**/.turbo/
**/.cache/
coverage/

# Python virtualenv and cache (all levels)
**/.venv/
**/venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Expo / React Native
frontend/mobile/.expo/
frontend/mobile/.expo-shared/

# ML generated artifacts
ml-service/runs/
ml-service/artifacts/
ml-service/data/*
!ml-service/data/.gitkeep
ml-service/models/*
!ml-service/models/.gitkeep
!ml-service/models/vehicle_best.pt
!ml-service/models/vehicle_best.meta.json
!ml-service/models/yolov8n.pt

# Local model weights
ml-service/*.pt
ml-service/*.onnx
ml-service/models/**/*.pt
!ml-service/models/yolov8n.pt

# Local datasets/videos
ml-service/data/**/*.mp4
ml-service/data/**/*.avi
ml-service/data/**/*.mov
ml-service/data/**/*.mkv
ml-service/data/**/*.m4v

# Local SQLite runtime databases
backend/data/*.sqlite
backend/data/*.sqlite-shm
backend/data/*.sqlite-wal
backend/data/access-control.runtime.json
